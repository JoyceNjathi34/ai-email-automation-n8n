    {
      "parameters": {
        "jsCode": "// Get AI output safely\nconst aiOutput = $input.first().json.output || $input.first().json.text;\nif (!aiOutput) {\n  throw new Error(\"AI Agent returned empty output\");\n}\n\n// Extract JSON block between first { and last }\nconst start = aiOutput.indexOf(\"{\");\nconst end = aiOutput.lastIndexOf(\"}\");\nif (start === -1 || end === -1 || end <= start) {\n  throw new Error(\"No JSON object found in AI output:\\n\" + aiOutput);\n}\n\nlet raw = aiOutput.slice(start, end + 1);\n\n// Remove any leftover markdown/code fences\nraw = raw.replace(/```json|```/gi, '').trim();\n\n// Parse JSON safely\nlet parsed = {};\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  console.error(\"Raw AI output:\", raw);\n  throw new Error(\"Invalid JSON from AI Agent\");\n}\n\n// Defaults\nconst defaults = {\n  priority: \"UNKNOWN\",\n};\n\n\n// Merge parsed data with defaults\nreturn [{ json: { ...defaults, ...parsed } }];"
      },
      "type": "n8n-nodes-base.code",
